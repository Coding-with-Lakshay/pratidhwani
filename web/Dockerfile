# --- builder ----------------------------------------------------------------
FROM node:24-alpine AS builder
WORKDIR /app

# Reproducible installs. Lock file is generated by local npm 11; node:24-alpine
# ships npm 11, so npm ci on the same lock-file format works in the container.
COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci --no-audit --no-fund; else npm install --no-audit --no-fund; fi

COPY tsconfig.json tsconfig.node.json vite.config.ts tailwind.config.ts postcss.config.js index.html ./
COPY src ./src
COPY public ./public

ENV NODE_ENV=production
RUN npm run build

# --- runtime ----------------------------------------------------------------
FROM nginx:1.27-alpine AS runtime

# Drop root capabilities we do not need at runtime
RUN apk add --no-cache gettext tini && \
    rm -rf /usr/share/nginx/html/* && \
    rm /etc/nginx/conf.d/default.conf

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf.template /etc/nginx/templates/default.conf.template
COPY entrypoint.sh /usr/local/bin/entrypoint.sh

RUN chmod +x /usr/local/bin/entrypoint.sh && \
    mkdir -p /var/cache/nginx /var/run /etc/nginx/conf.d && \
    chown -R nginx:nginx /var/cache/nginx /var/run /usr/share/nginx/html /etc/nginx/conf.d /etc/nginx/templates && \
    touch /var/run/nginx.pid && chown nginx:nginx /var/run/nginx.pid

# Cloud Run defaults to PORT=8080; we honor it.
ENV PORT=8080
ENV API_URL=http://localhost:8080
ENV PB_URL=http://localhost:8090

EXPOSE 8080
USER nginx

ENTRYPOINT ["/sbin/tini", "--", "/usr/local/bin/entrypoint.sh"]
